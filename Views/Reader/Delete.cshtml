@model LMS.Models.Reader

<h2>Delete Reader</h2>

<p>Are you sure you want to delete this reader?</p>

<div>
    <strong>ID:</strong> @Model.Id <br />
    <strong>Name:</strong> @Model.FirstName @Model.LastName <br />
    <strong>Email:</strong> @Model.Email <br />
    <strong>Phone:</strong> @Model.PhoneNumber <br />
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger mt-3">Delete</button>
    <a href="/Reader" class="btn btn-secondary mt-3">Cancel</a>
</form>