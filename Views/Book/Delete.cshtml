@model LMS.Models.Book

<h2>Delete Book</h2>

<p>Are you sure you want to delete this book?</p>

<div>
    <strong>ID:</strong> @Model.Id <br />
    <strong>Title:</strong> @Model.Title <br />
    <strong>Author:</strong> @Model.Author <br />
    <strong>Category:</strong> @Model.Category <br />
</div>

<form asp-action="Delete" method="post">
    <input type="hidden" asp-for="Id" />
    <button type="submit" class="btn btn-danger mt-3">Delete</button>
    <a href="/Book" class="btn btn-secondary mt-3">Cancel</a>
</form>
