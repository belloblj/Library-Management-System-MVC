@model List<LMS.Models.Book>

<h2>Books</h2>

<p>
    <a class="btn btn-primary" href="/Book/Create">Add New Book</a>
</p>

<table class="table table-striped table-hover shadow-sm">    @* zebra stripes, hover effect, and a soft shadow for better look *@
    <thead>
        <tr>
            <th>ID</th>
            <th>Title</th>
            <th>Author</th>
            <th>Category</th>
            <th>Total Copies</th>
            <th>Available Copies</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Id</td>
                <td>@b.Title</td>
                <td>@b.Author</td>
                <td>@b.Category</td>
                <td>@b.TotalCopies</td>
                <td>@b.AvailableCopies</td>
                <td>
                    <a class="btn btn-warning" href="/Book/Edit/@b.Id">Edit</a>
                    <a class="btn btn-danger" href="/Book/Delete/@b.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>