@model List<LMS.Models.Borrowing>

<h2>Borrowings</h2>

<p>
    <a class="btn btn-primary" href="/Borrowing/Create">Create New Borrowing</a>
</p>

<table class="table table-striped table-hover shadow-sm">
    @* zebra stripes, hover effect, and a soft shadow for better look *@
    <thead>
        <tr>
            <th>ID</th>
            <th>Book ID</th>
            <th>Reader ID</th>
            <th>Borrow Date</th>
            <th>Due Date</th>
            <th>Return Date</th>
            <th>Overdue Charge</th>
            <th>Actions</th>
        </tr>
    </thead>

    <tbody>
        @foreach (var b in Model)
        {
            <tr>
                <td>@b.Id</td>
                <td>@b.BookId</td>
                <td>@b.ReaderId</td>
                <td>@b.BorrowDate.ToShortDateString()</td>
                <td>@b.DueDate.ToShortDateString()</td>
                <td>@(b.ReturnDate?.ToShortDateString() ?? "Not Returned")</td>
                <td>@b.OverdueCharge</td>
                <td>
                    <a class="btn btn-warning" href="/Borrowing/Edit/@b.Id">Edit</a>
                    <a class="btn btn-danger" href="/Borrowing/Delete/@b.Id">Delete</a>
                </td>
            </tr>
        }
    </tbody>
</table>